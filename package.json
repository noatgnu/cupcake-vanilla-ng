{
  "name": "cupcake-vanilla-ng",
  "version": "0.0.3",
  "scripts": {
    "ng": "ng",
    "start": "npm run build:libs && ng serve",
    "build": "ng build",
    "build:libs": "node -e \"const { spawnSync } = require('child_process'); const script = process.platform === 'win32' ? 'build-all.bat' : './build-all.sh'; const res = spawnSync(script, { shell: true, stdio: 'inherit' }); process.exit(res.status);\"",
    "build:all": "npm run build:libs",
    "build:core": "ng build '@noatgnu/cupcake-core'",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:integration": "jest --config integration-test.config.json --runInBand --detectOpenHandles",
    "test:integration:coverage": "jest --config integration-test.config.json --runInBand --coverage --detectOpenHandles",
    "test:integration:watch": "jest --config integration-test.config.json --runInBand --watch",
    "test:integration:report": "jest --config integration-test.config.json --runInBand --reporters=default --reporters=jest-junit --outputFile=integration-test-results/junit.xml",
    "test:full-backend": "./full-backend-integration-test.sh",
    "publish:core": "cd dist/cupcake-core && npm publish --access public",
    "publish:vanilla": "cd dist/cupcake-vanilla && npm publish --access public",
    "publish:macaron": "cd dist/cupcake-macaron && npm publish --access public",
    "publish:mint-chocolate": "cd dist/cupcake-mint-chocolate && npm publish --access public",
    "publish:red-velvet": "cd dist/cupcake-red-velvet && npm publish --access public",
    "publish:salted-caramel": "cd dist/cupcake-salted-caramel && npm publish --access public",
    "publish:all": "npm run build:all && npm run publish:core && npm run publish:vanilla && npm run publish:macaron && npm run publish:mint-chocolate && npm run publish:red-velvet && npm run publish:salted-caramel",
    "electron:dev:server": "cd electron-app && npm run dev:server",
    "electron:dev:built": "ng build --configuration=electron && cd electron-app && npm run dev:built",
    "electron:build": "npm run build:libs && cd electron-app && npm run build",
    "electron:build:win": "npm run build:libs && cd electron-app && npm run build:win",
    "electron:build:mac": "npm run build:libs && cd electron-app && npm run build:mac",
    "electron:build:linux": "npm run build:libs && cd electron-app && npm run build:linux",
    "excel:start": "npm run build:libs && node projects/cupcake-excel-addin/scripts/serve.js --port 3000",
    "excel:build": "npm run build:libs && ng build cupcake-excel-addin",
    "excel:build:prod": "npm run build:libs && ng build cupcake-excel-addin --configuration production",
    "excel:sideload": "office-addin-debugging start projects/cupcake-excel-addin/manifest.xml desktop",
    "excel:stop": "office-addin-debugging stop projects/cupcake-excel-addin/manifest.xml",
    "excel:generate-certs": "office-addin-dev-certs install --days 365",
    "excel:validate-manifest": "office-addin-manifest validate projects/cupcake-excel-addin/manifest.xml",
    "excel:test": "playwright test --config=projects/cupcake-excel-addin/playwright.config.ts",
    "excel:test:ui": "playwright test --config=projects/cupcake-excel-addin/playwright.config.ts --ui",
    "excel:test:headed": "playwright test --config=projects/cupcake-excel-addin/playwright.config.ts --headed"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/platform-browser": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@noatgnu/cupcake-core": "file:./dist/cupcake-core",
    "@noatgnu/cupcake-macaron": "file:./dist/cupcake-macaron",
    "@noatgnu/cupcake-mint-chocolate": "file:./dist/cupcake-mint-chocolate",
    "@noatgnu/cupcake-red-velvet": "file:./dist/cupcake-red-velvet",
    "@noatgnu/cupcake-salted-caramel": "file:./dist/cupcake-salted-caramel",
    "@noatgnu/cupcake-vanilla": "file:./dist/cupcake-vanilla",
    "@popperjs/core": "^2.11.8",
    "@types/jssha": "^2.0.0",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "bootstrap": "^5.3.6",
    "bootstrap-icons": "^1.13.1",
    "jssha": "^3.3.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.2",
    "@angular/localize": "^21.2.2",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/office-js": "^1.0.588",
    "jasmine-core": "~5.8.0",
    "jest": "^30.1.3",
    "jsdom": "^28.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.2.0",
    "node-fetch": "^3.3.2",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-manifest": "^2.1.2",
    "puppeteer": "^24.39.1",
    "ts-jest": "^29.4.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1"
  }
}
